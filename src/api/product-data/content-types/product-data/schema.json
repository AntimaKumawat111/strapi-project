{
  "kind": "collectionType",
  "collectionName": "product_datas",
  "info": {
    "singularName": "product-data",
    "pluralName": "product-datas",
    "displayName": "productData"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "price": {
      "type": "integer",
      "required": true
    },
    "discountPercent": {
      "type": "integer"
    },
    "productImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "hotDeal": {
      "type": "boolean"
    },
    "sponsered": {
      "type": "boolean"
    },
    "seller": {
      "type": "string"
    },
    "availableOffers": {
      "type": "component",
      "component": "product.available-offers",
      "repeatable": true
    },
    "color": {
      "type": "component",
      "component": "color.color",
      "repeatable": true
    },
    "highlights": {
      "type": "component",
      "component": "highlights.highlights",
      "repeatable": true
    }
  }
}
